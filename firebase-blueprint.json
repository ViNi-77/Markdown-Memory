{
  "entities": {
    "Folder": {
      "title": "Folder",
      "description": "A folder to group markdown documents",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Folder name" },
        "parentId": { "type": ["string", "null"], "description": "Parent folder ID or null" },
        "createdAt": { "type": "number", "description": "Creation timestamp" }
      },
      "required": ["name", "createdAt"]
    },
    "MarkdownDocument": {
      "title": "MarkdownDocument",
      "description": "A markdown document with its content",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "content": { "type": "string" },
        "folderId": { "type": ["string", "null"] },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}/folders/{folderId}": {
      "schema": { "$ref": "#/entities/Folder" },
      "description": "Stores user folders"
    },
    "/users/{userId}/documents/{documentId}": {
      "schema": { "$ref": "#/entities/MarkdownDocument" },
      "description": "Stores user markdown documents"
    }
  }
}
