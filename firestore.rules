rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    function isValidFolder(data) {
      return data.keys().hasAll(['name', 'createdAt'])
        && data.name is string && data.name.size() > 0
        && data.createdAt is number;
    }

    function isValidDocument(data) {
      return data.keys().hasAll(['name', 'content', 'createdAt'])
        && data.name is string && data.name.size() > 0
        && data.content is string
        && data.createdAt is number;
    }

    match /users/{userId}/folders/{folderId} {
      allow read: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId)
                    && isValidId(folderId)
                    && isValidFolder(incoming());
      allow update: if isSignedIn() && isOwner(userId)
                    && isValidId(folderId)
                    && isValidFolder(incoming());
      allow delete: if isSignedIn() && isOwner(userId) && isValidId(folderId);
    }

    match /users/{userId}/documents/{documentId} {
      allow read: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId)
                    && isValidId(documentId)
                    && isValidDocument(incoming());
      allow update: if isSignedIn() && isOwner(userId)
                    && isValidId(documentId)
                    && isValidDocument(incoming());
      allow delete: if isSignedIn() && isOwner(userId) && isValidId(documentId);
    }
  }
}
