# Neon (PostgreSQL) — Vercel の Storage で Neon を追加すると自動発行される接続文字列。
# Vercel: Project > Storage > Neon、または Project > Settings > Environment Variables の DATABASE_URL をコピー。
DATABASE_URL=

# Auth.js (NextAuth v5) — Phase 3 で使用。
# AUTH_SECRET は `npx auth secret` で生成できる。
AUTH_SECRET=
# Google OAuth クライアント（Google Cloud Console で発行）。
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Vercel AI Gateway（推奨）
# Vercel Production では OIDC を利用できます。ローカル/CIなど静的キーが必要な環境で設定します。
AI_GATEWAY_API_KEY=

# AI Gateway model overrides（任意）
AI_MODEL_CLAUDE=
AI_MODEL_GPT=
AI_MODEL_GEMINI=

# Gemini API（任意・legacy fallback）
# GeminiモードでユーザーBYOKがなく、Gatewayではなく従来のGemini直結を使いたい場合だけ設定します。
GEMINI_API_KEY=
GEMINI_MODEL=

# 外部エラー通知（任意）
# HTTPS のWebhook URLだけ使用します。本文/APIキー/DB接続URLは送らない設計です。
ERROR_REPORT_WEBHOOK_URL=

# Vercel Cronの内部ヘルスチェック保護用。32文字以上のランダム値をVercelに設定。
CRON_SECRET=

# Neon バックアップ/復元ドリル（任意・ローカル運用用）
BACKUP_DIR=
BACKUP_FILE=
RESTORE_DATABASE_URL=
