# Neon (PostgreSQL) — Vercel の Storage で Neon を追加すると自動発行される接続文字列。
# Vercel: Project > Storage > Neon、または Project > Settings > Environment Variables の DATABASE_URL をコピー。
DATABASE_URL=

# Auth.js (NextAuth v5) — Phase 3 で使用。
# AUTH_SECRET は `npx auth secret` で生成できる。
AUTH_SECRET=
# Google OAuth クライアント（Google Cloud Console で発行）。
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Gemini API（任意・BYOK未設定時のサーバー側フォールバック）
GEMINI_API_KEY=

# 外部エラー通知（任意）
# HTTPS のWebhook URLだけ使用します。本文/APIキー/DB接続URLは送らない設計です。
ERROR_REPORT_WEBHOOK_URL=

# Neon バックアップ/復元ドリル（任意・ローカル運用用）
BACKUP_DIR=
BACKUP_FILE=
RESTORE_DATABASE_URL=
